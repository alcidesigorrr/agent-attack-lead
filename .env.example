# ============================================================================
# agent-attack-lead — .env
# Copie para .env e preencha todos os valores antes de subir o stack
# ============================================================================

# ── Nome do agente (usado pra multi-tenant) ────────────────────────────────
AGENT_ID=ana-seunegocio
AGENT_NAME="Ana"

# ── EvolutionAPI ────────────────────────────────────────────────────────────
EVO_API_KEY=gere_com_openssl_rand_hex_32

# ── PostgreSQL (local Evolution) ────────────────────────────────────────────
POSTGRES_PASSWORD=gere_com_openssl_rand_base64_24

# ── n8n ─────────────────────────────────────────────────────────────────────
N8N_ENCRYPTION_KEY=gere_com_openssl_rand_hex_32
N8N_ADMIN_USER=admin
N8N_ADMIN_PASSWORD=senha_forte_20chars

# ── Gemini (Google AI Studio) ──────────────────────────────────────────────
# Pegue em https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy...

# ── Supabase (backend CRM) ──────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...
SUPABASE_DB_PASSWORD=senha_do_database_supabase

# ── Webhooks (backend CRM que Ana vai chamar) ──────────────────────────────
# URL pública do seu Next.js (ex: https://seunegocio.com.br)
BACKEND_BASE_URL=https://seunegocio.com.br
# Secret compartilhado entre n8n e seu backend
OPENCLAW_WEBHOOK_SECRET=gere_com_openssl_rand_hex_32

# ── Telegram (opcional — notificação de lead quente) ───────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# ── Timezone ───────────────────────────────────────────────────────────────
TZ=America/Sao_Paulo
